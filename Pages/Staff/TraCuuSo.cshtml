@page
@model QuanLyTienGui.Pages.Staff.TraCuuSoModel
@{
    ViewData["Title"] = "Tra Cứu Sổ Tiết Kiệm";
}

<div class="container-fluid mt-3">
    <h3 class="text-primary fw-bold mb-4"><i class="bi bi-search"></i> Tra Cứu Danh Sách Sổ Tiết Kiệm</h3>

    @if (!string.IsNullOrEmpty(Model.SuccessMsg))
    {
        <div class="alert alert-success fw-bold shadow-sm fs-5">
            <i class="bi bi-check-circle-fill"></i> @Model.SuccessMsg
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMsg))
    {
        <div class="alert alert-danger fw-bold shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMsg
        </div>
    }

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="post" class="row g-3 align-items-end">
                <div class="col-md-9">
                    <input type="text" asp-for="TuKhoa" class="form-control form-control-lg border-info" placeholder="Nhập Mã Sổ (STK...) hoặc Tên khách hàng để lọc..." />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-info text-white fw-bold w-100 btn-lg">
                        Lọc Dữ Liệu
                    </button>
                    <a href="/Staff/TraCuuSo" class="btn btn-outline-secondary btn-lg fw-bold">Làm mới</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 text-center align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã Sổ</th>
                            <th>Khách Hàng</th>
                            <th>Loại Tiết Kiệm</th>
                            <th>Số Dư Hiện Tại</th>
                            <th>Ngày Đáo Hạn</th>
                            <th>Trạng Thái</th>
                            <th>Lối Tắt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.DanhSachSo.Count == 0)
                        {
                            <tr><td colspan="7" class="text-muted p-5 fst-italic">Không tìm thấy dữ liệu sổ tiết kiệm nào.</td></tr>
                        }

                        @foreach (var item in Model.DanhSachSo)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.MaSo</td>
                                <td class="text-start fw-bold">@item.TenKhachHang</td>
                                <td>@item.TenLoai</td>
                                <td class="text-success fw-bold">@item.SoDu.ToString("N0") đ</td>
                                <td class="fw-bold text-danger">@item.NgayDaoHan.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.TrangThai == "Đang hoạt động")
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.TrangThai</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/Staff/GuiThemTien?MaSoTietKiem=@item.MaSo" class="btn btn-sm btn-outline-primary" title="Nạp thêm tiền">Nạp</a>

                                        <a href="/Staff/RutTien?MaSoTietKiem=@item.MaSo" class="btn btn-sm btn-outline-danger" title="Tất toán sổ">Tất Toán</a>

                                        @if (item.TrangThai == "Đang hoạt động")
                                        {
                                            <a href="/Staff/TaiTucSo?MaSoTietKiem=@item.MaSo" class="btn btn-sm btn-warning text-dark fw-bold" title="Gia hạn kỳ mới">
                                                <i class="bi bi-arrow-repeat"></i> Tái Tục
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>