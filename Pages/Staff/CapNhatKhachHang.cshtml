@page
@model QuanLyTienGui.Pages.Staff.CapNhatKhachHangModel
@{
    ViewData["Title"] = "Cập Nhật Hồ Sơ Khách Hàng";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark fw-bold">
                <h4 class="m-0"><i class="bi bi-pencil-square"></i> Chỉnh Sửa Thông Tin Khách Hàng</h4>
            </div>
            <div class="card-body bg-light">
                @if (!string.IsNullOrEmpty(Model.ErrorMsg))
                {
                    <div class="alert alert-danger fw-bold shadow-sm">@Model.ErrorMsg</div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMsg))
                {
                    <div class="alert alert-success fw-bold shadow-sm">@Model.SuccessMsg</div>
                }

                <form method="post">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="fw-bold text-muted">Mã Khách Hàng</label>
                            <input type="text" asp-for="MaKhachHang" class="form-control bg-light fw-bold text-primary" readonly />
                        </div>
                        <div class="col-md-8">
                            <label class="fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input type="text" asp-for="HoTen" class="form-control text-uppercase" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold text-muted">Số CCCD (Bất biến)</label>
                            <input type="text" asp-for="CCCD" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Ngày Sinh <span class="text-danger">*</span></label>
                            <input type="date" asp-for="NgaySinh" class="form-control" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">Số Điện Thoại <span class="text-danger">*</span></label>
                            <input type="text" asp-for="DienThoai" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Email</label>
                            <input type="email" asp-for="Email" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="fw-bold">Địa Chỉ</label>
                        <textarea asp-for="DiaChi" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="d-flex justify-content-between gap-3">
                        <a asp-page="/Staff/TraCuu" class="btn btn-secondary fw-bold px-4">Quay lại danh sách</a>
                        <button type="submit" class="btn btn-warning text-dark fw-bold flex-grow-1">LƯU CẬP NHẬT HỒ SƠ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>