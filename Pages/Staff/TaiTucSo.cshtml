@page
@model QuanLyTienGui.Pages.Staff.TaiTucSoModel
@{
    ViewData["Title"] = "Tái Tục Sổ Tiết Kiệm";
}

<div class="container-fluid mt-3">
    <h3 class="text-warning text-darken fw-bold mb-4"><i class="bi bi-arrow-repeat"></i> Giao Dịch Tái Tục Sổ (Gia Hạn Kỳ Mới)</h3>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success fw-bold shadow-sm fs-5 text-center">
            <i class="bi bi-check-circle-fill"></i> @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger fw-bold shadow-sm text-center fs-5">
            <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage
        </div>
    }

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="post" asp-page-handler="TruyVan" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="fw-bold">Mã Sổ Cần Tái Tục <span class="text-danger">*</span></label>
                    <input type="text" asp-for="MaSoTietKiem" class="form-control text-uppercase fw-bold border-warning" required placeholder="VD: STK0001" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2"><i class="bi bi-search"></i> Kiểm Tra</button>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.TenKhachHang))
    {
        <div class="row">
            <div class="col-md-5">
                <div class="card shadow border-warning h-100">
                    <div class="card-header bg-warning text-dark fw-bold">
                        ⚙️ Lệnh Xử Lý Giao Dịch
                    </div>
                    <div class="card-body bg-light text-center d-flex flex-column justify-content-center">
                        <p class="text-muted mb-1 fw-bold text-uppercase">TỔNG SỐ DƯ MỚI (Dự kiến)</p>
                        <h1 class="text-warning text-darken fw-bold mb-4 display-5">
                            @if (Model.ChoPhepTaiTuc)
                            {
                                @Model.SoDuMoi.ToString("N0")
                            }
                            else
                            {

                                @Model.SoDuHienTai.ToString("N0")
                            }
     <span class="fs-4">đ</span>
                        </h1>

                        @if (!Model.ChoPhepTaiTuc)
                        {
                            <div class="alert alert-danger fw-bold mb-0 text-start">
                                <i class="bi bi-x-circle-fill"></i> @Model.ThongBaoNghiepVu
                            </div>
                            <button type="button" class="btn btn-secondary btn-lg w-100 fw-bold py-3 mt-3 shadow-sm" disabled>
                                KHÔNG ĐỦ ĐIỀU KIỆN TÁI TỤC
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-info text-dark fw-bold mb-3 text-start">
                                <i class="bi bi-info-circle-fill"></i> @Model.ThongBaoNghiepVu
                            </div>
                            <form method="post" asp-page-handler="XacNhanTaiTuc">
                                <input type="hidden" asp-for="MaSoTietKiem" />
                                <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold py-3 shadow-sm" onclick="return confirm('Chắc chắn kết toán lãi và gia hạn sổ này sang kỳ mới?');">
                                    <i class="bi bi-check2-all"></i> XÁC NHẬN TÁI TỤC SỔ
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-header bg-dark text-white fw-bold">
                        📊 Đối Chiếu Biến Động Kỳ Hạn
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-bordered mb-0 align-middle">
                            <tbody>
                                <tr><td class="bg-light fw-bold" style="width:35%">Khách Hàng</td><td class="text-primary fw-bold fs-5">@Model.TenKhachHang</td></tr>
                                <tr><td class="bg-light fw-bold">Sản Phẩm</td><td class="fw-bold">@Model.TenLoaiTietKiem</td></tr>
                                <tr><td class="bg-light fw-bold">Lãi Suất Áp Dụng</td><td class="text-success fw-bold">@Model.LaiSuat.ToString("0.##") % / Năm</td></tr>

                                <tr class="table-secondary"><th colspan="2" class="text-center text-muted">DỮ LIỆU KỲ CŨ (HIỆN TẠI)</th></tr>
                                <tr><td class="bg-light fw-bold ps-4">Ngày Đáo Hạn</td><td class="text-danger fw-bold">@Model.NgayDaoHan.ToString("dd/MM/yyyy")</td></tr>
                                <tr><td class="bg-light fw-bold ps-4">Tiền Gốc Ban Đầu</td><td class="fw-bold">@Model.SoDuHienTai.ToString("N0") VNĐ</td></tr>
                                <tr><td class="bg-light fw-bold ps-4 text-success">Lãi Sinh Lời Dự Kiến</td><td class="text-success fw-bold fs-5">+ @Model.TienLaiDuTinh.ToString("N0") VNĐ</td></tr>

                                @if (Model.ChoPhepTaiTuc)
                                {
                                    <tr class="table-warning"><th colspan="2" class="text-center text-dark">DỰ PHÓNG KỲ MỚI (SAU KHI TÁI TỤC)</th></tr>
                                    <tr><td class="bg-light fw-bold ps-4">Ngày Đáo Hạn Mới</td><td class="text-primary fw-bold">@Model.NgayDaoHanMoi.ToString("dd/MM/yyyy")</td></tr>
                                    <tr><td class="bg-light fw-bold ps-4 text-primary fs-5">Tổng Gốc Mới</td><td class="text-primary fw-bold fs-4">@Model.SoDuMoi.ToString("N0") VNĐ</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* CSS hỗ trợ màu nền warning đậm hơn một chút cho đẹp */
    .bg-warning {
        background-color: #ffc107 !important;
    }

    .text-warning.text-darken {
        color: #d39e00 !important;
    }
</style>