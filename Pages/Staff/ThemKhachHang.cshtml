@page
@model QuanLyTienGui.Pages.Staff.ThemKhachHangModel
@{
    ViewData["Title"] = "Thêm Khách Hàng Mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white">
                <h4 class="m-0"><i class="bi bi-person-plus-fill"></i> Tạo Hồ Sơ Khách Hàng</h4>
            </div>
            <div class="card-body bg-light">
                @if (!string.IsNullOrEmpty(Model.ErrorMsg))
                {
                    <div class="alert alert-danger fw-bold shadow-sm">@Model.ErrorMsg</div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMsg))
                {
                    <div class="alert alert-success fw-bold shadow-sm">@Model.SuccessMsg</div>
                }

                <form method="post">
                    <div class="form-group mb-3">
                        <label class="fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                        <input type="text" asp-for="HoTen" class="form-control text-uppercase" required placeholder="Nhập họ tên đầy đủ..." />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">Số CCCD <span class="text-danger">*</span></label>
                            <input type="text" asp-for="CCCD" class="form-control" required maxlength="12" placeholder="Nhập 12 số CCCD..." />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Ngày Sinh <span class="text-danger">*</span></label>
                            <input type="date" asp-for="NgaySinh" class="form-control" required />
                            <small class="text-muted fst-italic">Khách hàng phải từ đủ 18 tuổi.</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">Số Điện Thoại <span class="text-danger">*</span></label>
                            <input type="text" asp-for="DienThoai" class="form-control" required maxlength="15" placeholder="SĐT liên hệ..." />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">Email</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="example@gmail.com" />
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="fw-bold">Địa Chỉ Thường Trú</label>
                        <textarea asp-for="DiaChi" class="form-control" rows="2" placeholder="Nhập địa chỉ cư trú..."></textarea>
                    </div>

                    <div class="d-flex justify-content-between gap-3">
                        <a asp-page="/Staff/TraCuu" class="btn btn-secondary fw-bold px-4">Hủy / Quay Lại</a>
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1">LƯU HỒ SƠ KHÁCH HÀNG</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>