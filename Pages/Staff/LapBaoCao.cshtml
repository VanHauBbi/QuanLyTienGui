@page
@model QuanLyTienGui.Pages.Staff.LapBaoCaoModel
@{
    ViewData["Title"] = "Lập Báo Cáo Chốt Ca";
}

<div class="container-fluid mt-3">
    <h3 class="text-primary fw-bold mb-4"><i class="bi bi-file-earmark-bar-graph-fill"></i> Lập Báo Cáo Giao Dịch & Chốt Ca</h3>

    @if (!string.IsNullOrEmpty(Model.SuccessMsg))
    {
        <div class="alert alert-success fw-bold shadow-sm fs-5">
            <i class="bi bi-check-circle-fill"></i> @Model.SuccessMsg
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMsg))
    {
        <div class="alert alert-danger fw-bold shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMsg
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 opacity-75">TỔNG THU (Khách nộp)</h6>
                    <h2 class="fw-bold m-0">@Model.TongThu.ToString("N0") <small class="fs-6">VNĐ</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white shadow">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 opacity-75">TỔNG CHI (Khách rút)</h6>
                    <h2 class="fw-bold m-0">@Model.TongChi.ToString("N0") <small class="fs-6">VNĐ</small></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-dark shadow">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 opacity-75">SỐ LƯỢNG GIAO DỊCH</h6>
                    <h2 class="fw-bold m-0">@Model.TongGiaoDich <small class="fs-6">Lượt</small></h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm border-primary h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    📝 Soạn Thảo / Chốt Quỹ
                </div>
                <div class="card-body bg-light">
                    <form method="post">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="fw-bold mb-1 text-muted">Người Lập</label>
                                <input type="text" class="form-control fw-bold bg-white" value="@User.Identity.Name" readonly />
                            </div>
                            <div class="col-6">
                                <label class="fw-bold mb-1 text-muted">Thời Gian Lập</label>
                                <input type="text" class="form-control bg-white fst-italic" value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly />
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="fw-bold text-primary mb-2">Nội Dung Chi Tiết (Có thể chỉnh sửa) <span class="text-danger">*</span></label>
                            <textarea asp-for="NoiDung" class="form-control border-primary fw-bold" style="font-family: monospace;" rows="8" required></textarea>
                            <small class="text-muted fst-italic mt-1 d-block">Hệ thống đã tự động kết xuất số liệu giao dịch của bạn vào ô trên.</small>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" onclick="return confirm('Tiền quỹ đã khớp? Xác nhận gửi báo cáo chốt ca?');">
                            <i class="bi bi-send-fill"></i> NỘP BÁO CÁO CHỐT CA
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    🕒 Lịch Sử Báo Cáo Gần Đây
                </div>
                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 text-center align-middle">
                            <thead class="table-secondary sticky-top">
                                <tr>
                                    <th>Mã BC</th>
                                    <th>Thời Gian</th>
                                    <th style="width: 40%;">Nội Dung</th>
                                    <th>Trạng Thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DanhSachBaoCao.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-muted p-5 fst-italic">Bạn chưa nộp báo cáo nào.</td></tr>
                                }
                                @foreach (var bc in Model.DanhSachBaoCao)
                                {
                                    <tr>
                                        <td class="fw-bold text-secondary">@bc.MaBaoCao</td>
                                        <td>@bc.ThoiGianLap.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-start text-muted" style="white-space: pre-wrap; font-size: 0.85rem;">@bc.NoiDung</td>
                                        <td>
                                            @if (bc.TrangThai == "Chờ phê duyệt")
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                                            }
                                            <br />
                                            <small class="text-muted">@bc.NguoiDuyet</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>