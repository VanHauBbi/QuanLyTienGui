<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Chi Nhánh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-4">
            <div class="container-fluid px-5">
                <a class="navbar-brand fw-bold text-warning" asp-page="/Manager/Index">📊 Bảng Điều Khiển</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Manager/QuanLyNhanVien">👥 Nhân Sự</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="navDanhMuc" role="button" data-bs-toggle="dropdown">
                                📑 Danh Mục Cấu Hình
                            </a>
                            <ul class="dropdown-menu shadow-sm">
                                <li><a class="dropdown-item fw-bold text-primary" asp-page="/Manager/LoaiTietKiem">📋 Quản lý Loại Tiết Kiệm</a></li>
                                <li><a class="dropdown-item fw-bold text-danger" asp-page="/Manager/CapNhatLaiSuat">💰 Biểu Lãi Suất Thị Trường</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="navBaoCao" role="button" data-bs-toggle="dropdown">
                                📈 Kiểm Soát Báo Cáo
                            </a>
                            <ul class="dropdown-menu shadow-sm">
                                <li><a class="dropdown-item" asp-page="/Manager/BaoCaoDoanhSo">💵 Xem Báo Cáo Doanh Số</a></li>
                                <li><a class="dropdown-item" asp-page="/Manager/PheDuyetBaoCao">✅ Phê Duyệt Báo Cáo Ca</a></li>
                            </ul>
                        </li>

                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold bg-light rounded px-3" asp-page="/Account/Logout">Đăng xuất</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>