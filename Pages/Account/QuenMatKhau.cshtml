@page
@model QuanLyTienGui.Pages.Account.QuenMatKhauModel
@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-header bg-danger text-white text-center py-3">
                <h5 class="mb-0"><i class="bi bi-shield-exclamation"></i> KHÔI PHỤC MẬT KHẨU</h5>
            </div>
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.ErrorMsg))
                {
                    <div class="alert alert-danger shadow-sm">@Model.ErrorMsg</div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMsg))
                {
                    <div class="alert alert-success shadow-sm text-center">
                        @Model.SuccessMsg <br /><br />
                        <a asp-page="/Account/Login" class="btn btn-success px-4">Quay lại Đăng nhập</a>
                    </div>
                }
                else
                {
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input type="text" asp-for="TenDangNhap" class="form-control" required placeholder="Nhập tên tài khoản..." />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Email đăng ký <span class="text-danger">*</span></label>
                            <input type="email" asp-for="Email" class="form-control" required placeholder="Nhập email nhân viên..." />
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold">Khôi Phục Mật Khẩu</button>
                            <a asp-page="/Account/Login" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>